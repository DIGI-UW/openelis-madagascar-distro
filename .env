ADMIN_PASSWORD=superuser
OE_DB_PASSWORD=clinlims

SSL_TRUSTSTORE_PATH=/etc/openelis-global/truststore
SSL_TRUSTSTORE_PASSWORD=tspass
SSL_KEYSTORE_PATH=/etc/openelis-global/keystore
SSL_KEYSTORE_PASSWORD=kspass

# Host directory root for analyzer file drops (NFS, USB, network shares).
# The bridge watches subdirectories configured per-analyzer in the UI.
# Mounted at the same path inside containers so admin-typed paths work unchanged.
ANALYZER_HOST_MOUNT=/mnt

# Upstream image pins (release tag + digest for full reproducibility).
# Bump via: ./scripts/pin-versions.sh <oe-version> <bridge-version>
OE_VERSION=3.2.1.6
OE_BRIDGE_VERSION=3.0.1
OE_WEBAPP_IMAGE=itechuw/openelis-global-2:3.2.1.6@sha256:0fb3a4814ce8ab3106c84dd123982a50e2835aca391624d1e521a2bbdb883b7c
OE_FRONTEND_IMAGE=itechuw/openelis-global-2-frontend:3.2.1.6@sha256:e30e6aee229c8607fc6fac797d5e123736c4279dff4fa7cd86cc782509e25a3a
OE_DATABASE_IMAGE=itechuw/openelis-global-2-database:3.2.1.6@sha256:89c8e1cacbcf933ebcbb17686d946bd94964892cefe4cf57950981b71498cb7e
OE_FHIR_IMAGE=itechuw/openelis-global-2-fhir:3.2.1.6@sha256:92a21b841cc67777543b2d089a8cde9043e7ee2ebec368341a683246ec8fc5bd
OE_PROXY_IMAGE=itechuw/openelis-global-2-proxy:3.2.1.6@sha256:0e0f0245a8c4e97cbfa1483ef302c4fe9616acdc9ecdce4017ee93900a23567c
OE_BRIDGE_IMAGE=itechuw/openelis-analyzer-bridge:3.0.1@sha256:6d43bf5b5556863f107fe912d220f8ac0ae25fc3201ac38c861453ee5dbe5d43
OE_CERTGEN_IMAGE=itechuw/certgen:main@sha256:e27a8194300ba73309e835a4070e9ce531687eb3ee604895de781f3061791635
