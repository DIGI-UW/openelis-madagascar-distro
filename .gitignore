# Local secrets and env (do not commit credentials)
.env
.env.local
.env.*.local

# Locally-built release tarballs (scripts/build-tarball.sh output).
openelis-madagascar-distro-*.tar.gz

# Local compose overrides (auto-loaded by Docker Compose if present;
# machine-specific paths; see docs/validation.md).
compose.override.yaml
compose.override.yml
docker-compose.override.yml

# Database bind mounts and local OE config overrides
configs/logs/
configs/logs/*
configs/database/data/
configs/database/data2/
**/*checksum*.properties
**/*checksums*.properties
configs/properties/TotalSystemConfiguration.properties
configs/properties/ChangedSystemConfiguration.properties

# Runtime TLS / ACME volume (generated; track volume/**/.gitkeep as needed)
volume/letsencrypt/live/
volume/letsencrypt/archive/
volume/letsencrypt/renewal/
volume/letsencrypt/accounts/
volume/letsencrypt-staging/
volume/letsencrypt-staging-logs/

# Node and Playwright
node_modules/
test-results/
playwright-report/
blob-report/
**/playwright/.auth/

# CI and local validation artifacts
test-artifacts/

# IDE and OS
.cursor/
.claude/
.idea/
.DS_Store
