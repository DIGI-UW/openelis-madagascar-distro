# Vars consumed only by compose.letsencrypt.yaml (production TLS termination
# via Let's Encrypt). Leave these unset for localhost demos — the base
# `docker compose up -d` doesn't read them.
#
# To enable Let's Encrypt:
#   1. Copy this file to .env.letsencrypt and fill in your domain/email.
#   2. Append the values to .env (compose only auto-loads one .env file),
#      or pass both with docker compose --env-file flags.
#   3. Run with the overlay:
#        docker compose -f compose.yaml -f compose.letsencrypt.yaml up -d
#
# See docs/letsencrypt.md for the full setup walkthrough.

LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_DOMAINS=example.com
LETSENCRYPT_PRIMARY_DOMAIN=example.com
LETSENCRYPT_CERT_NAME=example.com
