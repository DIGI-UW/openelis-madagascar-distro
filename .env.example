# Madagascar OpenELIS distro — environment template.
# Copy to .env and edit. .env is gitignored; .env.example IS committed.
#
# Compose loads .env automatically from this directory (project root).
# Reference: compose.yaml, compose.validate.yaml, compose.letsencrypt.yaml.

# --- Image tags ----------------------------------------------------------
# Default published-image tag for OpenELIS images. scripts/restart-stack.sh
# --rebuild sets this to "local" after building from $OE_REPO.
OE_IMAGE_TAG=develop

# Independent tag for the analyzer bridge (lets you pin bridge changes
# without bumping the OE webapp). scripts/restart-stack.sh --rebuild leaves
# this as-is unless you explicitly export BRIDGE_IMAGE_TAG=local.
BRIDGE_IMAGE_TAG=develop

# --- Application credentials --------------------------------------------
# clinlims DB password (Postgres user that owns the OpenELIS schema).
OE_DB_PASSWORD=clinlims

# postgres superuser password (only used for DB init).
ADMIN_PASSWORD=superuser

# OpenELIS in-app admin password (Tomcat seeds this on first boot).
# Also used by the bridge to authenticate REST forwards back to OE.
OE_ADMIN_PASSWORD=adminADMIN!

# --- TLS material (truststore + keystore inside containers) -------------
SSL_TRUSTSTORE_PATH=/etc/openelis-global/truststore
SSL_TRUSTSTORE_PASSWORD=tspass
SSL_KEYSTORE_PATH=/etc/openelis-global/keystore
SSL_KEYSTORE_PASSWORD=kspass

# --- Analyzer file-drop host mount --------------------------------------
# Host directory root for analyzer file drops (NFS, USB, network shares).
# Mounted read-only at the same path inside webapp + bridge + demo-tests
# so admin-typed paths in the UI work unchanged.
ANALYZER_HOST_MOUNT=/mnt

# --- Let's Encrypt (compose.letsencrypt.yaml overlay) -------------------
# Required by scripts/generate-letsencrypt-certs.sh.
LETSENCRYPT_EMAIL=admin@mgtest.openelis-global.org

# Comma- or space-separated SAN list. Defaults below match this server.
LETSENCRYPT_DOMAINS=mgtest.openelis-global.org
LETSENCRYPT_PRIMARY_DOMAIN=mgtest.openelis-global.org
LETSENCRYPT_CERT_NAME=mgtest.openelis-global.org
