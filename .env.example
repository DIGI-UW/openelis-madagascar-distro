# OpenELIS Madagascar distro — environment overrides template.
#
# Copy to `.env` and edit only the values you want to override:
#
#     cp .env.example .env
#     # edit as needed
#     docker compose up -d
#
# Every value below is optional — `compose.yaml` ships sensible defaults
# (the same ones shown here) so `docker compose up -d` boots a healthy
# localhost-demo stack with no `.env` file at all. Override here for
# production deployments.
#
# `.env` is gitignored. Never commit it.

# --- Application credentials --------------------------------------------
# CHANGE THESE for non-localhost deployments.

# clinlims DB password (Postgres user that owns the OpenELIS schema).
OE_DB_PASSWORD=clinlims

# postgres superuser password (used during DB init only).
ADMIN_PASSWORD=superuser

# OpenELIS in-app admin password (Tomcat seeds this on first boot).
# Also used by the analyzer bridge to authenticate REST forwards.
OE_ADMIN_PASSWORD=adminADMIN!

# --- DB Volume Mount ----------------------------------------------------
# The local directory used to store the database so that its remains
# stable across restarts and is available to be backed-up.
DB_VOLUME_MOUNT=./configs/database/data

# --- Analyzer file-drop host mount --------------------------------------
# Host directory root for analyzer file drops (NFS, USB, network shares).
# Mounted read-only at the same path inside webapp + bridge so admin-typed
# paths in the UI work unchanged.
ANALYZER_HOST_MOUNT=/mnt

# --- TLS material (truststore + keystore paths inside containers) -------
SSL_TRUSTSTORE_PATH=/etc/openelis-global/truststore
SSL_TRUSTSTORE_PASSWORD=tspass
SSL_KEYSTORE_PATH=/etc/openelis-global/keystore
SSL_KEYSTORE_PASSWORD=kspass

# --- Let's Encrypt (only used with compose.letsencrypt.yaml overlay) ----
# Consumed by scripts/generate-letsencrypt-certs.sh and the proxy overlay.
# Leave commented out for localhost demos.
#
# To enable production TLS:
#   1. Uncomment + fill in the values below.
#   2. docker compose -f compose.yaml -f compose.letsencrypt.yaml up -d
#   3. ./scripts/generate-letsencrypt-certs.sh
#
# See docs/letsencrypt.md for the full walkthrough.

# LETSENCRYPT_EMAIL=admin@example.com
# LETSENCRYPT_DOMAINS=example.com
# LETSENCRYPT_PRIMARY_DOMAIN=example.com
# LETSENCRYPT_CERT_NAME=example.com
