{
  "$schema": "https://openelis-global.org/schemas/analyzer-defaults/1.0",
  "profileMeta": {
    "id": "genexpert-astm",
    "version": "1.2.0",
    "displayName": "Cepheid GeneXpert (ASTM Mode)"
  },
  "analyzer_name": "Cepheid GeneXpert (ASTM Mode)",
  "manufacturer": "Cepheid",
  "category": "MOLECULAR",
  "protocol": { "name": "ASTM", "version": "E-1394-97" },
  "identifier_pattern": ".*GeneExpert.*",
  "transport": ["RS-232", "TCP/IP"],
  "transport_config": {
    "RS-232": { "default_baud_rate": 9600 },
    "TCP/IP": {}
  },
  "default_test_mappings": [
    {
      "analyzer_code": "MTB",
      "test_name_hint": "Lymphocytes",
      "loinc": "736-9",
      "unit": ""
    },
     {
      "analyzer_code": "MTB Trace",
      "test_name_hint": "Monocytes",
      "loinc": "5905-5",
      "unit": ""
    }
  ],
  "configDefaults": {
    "connectionRole": "SERVER",
    "aggregationMode": "PER_MESSAGE",
    "qcRules": [],
    "extractionOverrides": {},
    "flagMappings": {},
    "transforms": {}
  },
  "notes": "Multi-protocol capable: FILE (primary), ASTM, HL7 all confirmed per Cepheid LIS spec. This config is for ASTM mode. Results are typically qualitative (Detected/Not Detected) for most assays. GeneXpert supports both RS-232 and TCP/IP transports."
}
